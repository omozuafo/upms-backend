APP_NAME="UPMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-render-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database - set DB_CONNECTION=pgsql and DATABASE_URL for Render PostgreSQL
DB_CONNECTION=pgsql
DATABASE_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# JWT - generate with: php artisan jwt:secret
JWT_SECRET=

# CORS - set to your deployed Vercel frontend URL
FRONTEND_URL=https://your-vercel-app.vercel.app

MAIL_MAILER=log
